# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role (Server-only, NEVER expose)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe Configuration (US)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret

# MercadoPago Configuration (Colombia)
EXPO_PUBLIC_MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000

# Environment
ENVIRONMENT=development

# Optional: Analytics
EXPO_PUBLIC_ANALYTICS_KEY=your_analytics_key

# ============================================================================
# PAYMENT PROVIDERS
# ============================================================================

# Stripe (US)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# MercadoPago (Colombia)
EXPO_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-YOUR_PUBLIC_KEY_HERE
MERCADOPAGO_ACCESS_TOKEN=APP_USR-YOUR_ACCESS_TOKEN_HERE

# API
EXPO_PUBLIC_API_URL=https://your-backend.com
