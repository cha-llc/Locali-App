{
  "expo": {
    "name": "Locali",
    "slug": "locali-mvp",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#124734"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": false,
      "bundleIdentifier": "com.chaholdingsltd.locali"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#124734"
      },
      "package": "com.chaholdingsltd.locali",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 21,
            "targetSdkVersion": 34
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Locali to access your camera for ID verification"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "locali-mvp"
      }
    }
  }
}
